# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (for AI quiz generation and QA)
OPENAI_API_KEY=sk-...

# PayFast
PAYFAST_MERCHANT_ID=your-merchant-id
PAYFAST_MERCHANT_KEY=your-merchant-key
PAYFAST_PASSPHRASE=your-passphrase
PAYFAST_SANDBOX=true
PAYFAST_RETURN_URL=http://localhost:3000/dashboard/orders
PAYFAST_CANCEL_URL=http://localhost:3000/dashboard/orders
PAYFAST_ITN_URL=https://your-domain.com/api/webhooks/payfast
